# Trading-Trip Environment Variables
# Copy this file to .env for local development (never commit .env)

# REQUIRED — Railway will auto-assign this
PORT=8080

# REQUIRED — generate a strong random string (e.g. openssl rand -hex 32)
# Without this, tokens reset every server restart
JWT_SECRET=change-me-to-a-long-random-secret

# OPTIONAL — enables live Claude AI insights
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — Alpha Vantage for additional stock data (free tier: 25 req/day)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
